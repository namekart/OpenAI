# Google SMTP credentials
# Use your Gmail address
SMTP_EMAIL=you@gmail.com

# Generate at: Google Account → Security → 2-Step Verification → App passwords
# Select "Mail" + your device, copy the 16-char password (spaces don't matter)
SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where contact form submissions get delivered (usually same as SMTP_EMAIL)
RECEIVER_EMAIL=you@gmail.com

# Optional: change the Express API port (default: 3001)
# PORT=3001
